# To use it:
#   docker build -f docker/Dockerfile.git -t tiki-git .
#   docker run --rm -it tiki-git
#
# The build context is not used (no COPY), so any directory works as context.
# The `-it` flags give you an interactive bash shell with git available.

FROM debian:bookworm-slim

ENV TERM=xterm-256color

RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates curl vim-tiny && rm -rf /var/lib/apt/lists/*

CMD ["bash"]
